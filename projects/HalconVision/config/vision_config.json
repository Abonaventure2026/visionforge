{
    "image": {
        "read_path": "./assets/",
        "save_path": "./output/"
    },
    "ocr": {
        "font_name": "Universal_0-9_NoRej",
        "min_stroke_width": 6,
        "text_line_structure": "2 2 2",
        "confidence_threshold": 0.5
    },
    "3d_structure": {
        "gray_bits": 8,
        "shift_steps": 4,
        "frequency": 16,
        "enable_ai_denoise": true
    },
    "defect": {
        "min_area": 10.0,
        "max_area": 10000.0,
        "min_score": 0.3
    },
    "camera": {
        "use_virtual": true,
        "frame_rate": 30,
        "exposure": 10000
    },
    "system": {
        "enable_gpu": true,
        "enable_tensorrt": false,
        "log_level": "INFO"
    }
}
